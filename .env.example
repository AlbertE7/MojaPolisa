# ============================================================
# MojaPolisa – zmienne środowiskowe
# Skopiuj jako .env.local i uzupełnij wartości
# NIGDY nie commituj .env.local do repozytorium!
# ============================================================

# ------------------------------------------------------------
# SUPABASE (ustawienia z projektu na app.supabase.com)
# ------------------------------------------------------------

# URL projektu Supabase (zakładka Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://TWOJ_PROJEKT.supabase.co

# Anon (public) key – bezpieczny dla przeglądarki
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key – TYLKO na serwerze (API Routes, Edge Functions)
# NIGDY nie ujawniaj klientowi!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Klucz szyfrowania AES-256 dla PESEL i danych zdrowotnych
# Wygeneruj: openssl rand -base64 32
# Ustaw też w Supabase: Settings → Vault → Secret (app.encryption_key)
ENCRYPTION_KEY=BASE64_32_BYTE_RANDOM_KEY

# JWT Secret (do weryfikacji tokenów Supabase)
SUPABASE_JWT_SECRET=TWOJ_JWT_SECRET

# ------------------------------------------------------------
# RESEND (email transakcyjne – resend.com)
# ------------------------------------------------------------

# API key z Resend Dashboard
RESEND_API_KEY=re_...

# Adres nadawcy (musi być zweryfikowaną domeną w Resend)
RESEND_FROM_EMAIL=noreply@finvita.pl

# Email agenta (dokąd wysyłać pełne wnioski)
AGENT_EMAIL=agent@epro-polska.pl

# ------------------------------------------------------------
# FIREBASE (push notyfikacje – FCM)
# ------------------------------------------------------------

# Firebase projekt ID (console.firebase.google.com)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=mojapolisa-XXXXX

# Firebase API Key (publiczny)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...

# Firebase App ID
NEXT_PUBLIC_FIREBASE_APP_ID=1:XXXXXXXXXX:web:XXXXXXXX

# Firebase Messaging Sender ID
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=XXXXXXXXXX

# Firebase VAPID Key (do web push – Firebase Console → Cloud Messaging → Web Push certificates)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=BNZk...

# Firebase Admin SDK (tylko serwer – do wysyłania push z API)
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-XXXXX@mojapolisa-XXXXX.iam.gserviceaccount.com

# ------------------------------------------------------------
# GOOGLE CLOUD VISION (OCR – placeholder, na przyszłość)
# ------------------------------------------------------------

GOOGLE_CLOUD_VISION_API_KEY=AIzaSy...

# ------------------------------------------------------------
# APLIKACJA
# ------------------------------------------------------------

# URL bazowy aplikacji web
NEXT_PUBLIC_APP_URL=https://finvita.pl

# Base path (aplikacja dostępna pod /mojapolisa)
NEXT_PUBLIC_BASE_PATH=/mojapolisa

# Sekret do głębokiego linku (token-based invite)
DEEP_LINK_SECRET=RANDOM_64_CHAR_HEX

# ------------------------------------------------------------
# ADMIN
# ------------------------------------------------------------

# Email admina (do logowania do panelu)
ADMIN_EMAIL=admin@epro-polska.pl

# Hasło admina (hash bcrypt – ustaw przez Supabase Auth Dashboard)
# Uwaga: konto admina tworzy się przez Supabase Auth, nie tu

# ------------------------------------------------------------
# PANEL ADMINA – autentykacja
# ------------------------------------------------------------

# Session timeout (sekundy) – domyślnie 1800 (30 min)
ADMIN_SESSION_TIMEOUT=1800

# ------------------------------------------------------------
# NEXT.JS
# ------------------------------------------------------------

# Środowisko (development | production)
NODE_ENV=development

# ------------------------------------------------------------
# EXPO / REACT NATIVE (apps/mobile)
# ------------------------------------------------------------

EXPO_PUBLIC_SUPABASE_URL=https://TWOJ_PROJEKT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
EXPO_PUBLIC_FIREBASE_PROJECT_ID=mojapolisa-XXXXX
EXPO_PUBLIC_APP_URL=https://finvita.pl/mojapolisa
